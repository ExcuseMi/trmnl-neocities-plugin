# How often to re-scrape Neocities (hours, decimals allowed — 0.5 = 30 min)
REFRESH_HOURS=0.5

# How many Neocities browse pages to scrape per sort option (100 sites/page)
NEOCITIES_PAGES=5

# whitelist_only: TRMNL IPs only (production default)
# rate_limited:   TRMNL unrestricted, public callers rate limited
# open:           no restrictions (local dev)
ACCESS_MODE=whitelist_only
IP_REFRESH_HOURS=24
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=300

# For Docker Compose: REDIS_HOST=redis
# For local dev:      REDIS_HOST=localhost
REDIS_HOST=redis
REDIS_PORT=6379

BACKEND_PORT=8733
